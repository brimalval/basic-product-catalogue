# SMTP configuration — all vars required when SMTP_HOST is set
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=your-password
SMTP_FROM=noreply@example.com
MAIL_TO=sales@example.com

# Frontend base URL — used to generate product links in enquiry emails (optional)
FRONTEND_URL=https://yourstore.com
