# Required
DATABASE_URL="file:./prisma/dev.db"
PORT=3001
NODE_ENV=development

# SMTP — all vars required together when SMTP_HOST is set; omit entirely to use dev-mail stub
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=your-password
SMTP_FROM=noreply@example.com
MAIL_TO=sales@example.com

# Frontend base URL — used to generate product links in enquiry emails (optional)
FRONTEND_URL=https://yourstore.com
